    "checkers = Checkers specific (state/movegen/eval/encoder/perft, checkers CLI)",
    "shared = used by more than one game without being fully generic",
    "external = third-party runtime/library (PyTorch, candle)",
    "deferred = planned but not yet wired; all its edges are dashed"
