      "id": "L3",
      "title": "Per-game glue (impl Game / Evaluator / Encoder)",
      "order": 2
    },
    {
      "id": "L4",
      "title": "Per-game rules (state, movegen, eval, features, books)",
      "order": 3
    },
    {
      "id": "L5",
      "title": "Offline training + data (trainer, datasets, weights)",
      "order": 4
    }
  ],
